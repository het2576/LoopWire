# Copy this file to .env and fill in real values. See SETUP.md for how to get each one.

# --- Database (Supabase Postgres connection string) ---
# Supabase dashboard -> Project Settings -> Database -> Connection string -> URI
# Use the "Session pooler" URI for compatibility with most hosts. Convert postgres:// to postgresql+psycopg2://
DATABASE_URL=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@[PROJECT-REF].supabase.co:5432/postgres

# --- Telegram (from @BotFather) ---
TELEGRAM_BOT_TOKEN=

# --- Gemini (Google AI Studio) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Resend (email delivery) - sender only; recipient is each user's own
# account email now that Loopwire is multi-tenant. ---
RESEND_API_KEY=
LOOPWIRE_FROM_EMAIL=hello@loopwire.yourdomain.dev

# --- URLs ---
DASHBOARD_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8000

# --- Send schedule (hour is in IST, Asia/Kolkata) - only used by the optional
# in-process scheduler; the default setup triggers sends via cron-job.org
# hitting /send-digest instead. See SETUP.md. ---
LOOPWIRE_PERIOD=daily
LOOPWIRE_SEND_HOUR_IST=9

# --- Telegram webhook mode ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_WEBHOOK_SECRET=

# --- /send-digest endpoint protection (required - endpoint refuses all
# requests if this is blank). Generate the same way as the webhook secret. ---
SEND_LOOPWIRE_SECRET=

# --- /process-pending endpoint protection (same fail-closed pattern) ---
PROCESS_PENDING_SECRET=

# --- Internal Next.js <-> FastAPI auth bridge (Phase A) ---
# Must match dashboard/.env.local's INTERNAL_AUTH_SECRET exactly.
# Generate the same way as the other secrets above.
INTERNAL_AUTH_SECRET=
